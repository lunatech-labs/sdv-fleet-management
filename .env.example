# HawkBit DDI gateway token — used by device-side components (ota-agent) that
# talk to /DEFAULT/controller/v1. Not used for Management API auth.
HAWKBIT_TOKEN=demo-token-change-me

# HawkBit Management API credentials — used by the backend to talk to
# /rest/v1. HawkBit's default admin user is admin:admin.
HAWKBIT_USER=admin
HAWKBIT_PASSWORD=admin
